# OpenAI (default)
LLM_PROVIDER=openai
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4.1-mini

# Claude (set LLM_PROVIDER=anthropic and use these instead of OpenAI)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

DM_API_PORT=8787
# Optional: durable session storage via Postgres/Neon.
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
# Optional: point this at a persistent disk mount in production.
# DATA_DIR=/var/data/dungeonmaister
