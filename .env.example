# Get a key from https://console.anthropic.com/ — never commit the real .env file.
ANTHROPIC_API_KEY=

# Optional: override model (must be available on your Anthropic account)
# Examples: claude-sonnet-4-20250514, claude-3-5-sonnet-20241022
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: port for server/dmServer.mjs (Vite proxies /api here in dev)
DM_API_PORT=8787
